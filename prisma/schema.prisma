// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────
// Identity
// ─────────────────────────────────────────────────────────

/// Mirrors auth.users.id (Supabase-managed). Prisma cannot reach into the
/// `auth` schema, so this is a logical 1:1 kept in sync by a Postgres
/// trigger (see prisma/migrations) plus a defensive upsert in requireUser().
model Profile {
  id        String   @id @default(uuid())
  email     String   @unique
  fullName  String?
  avatarUrl String?
  currency  String   @default("BRL")
  locale    String   @default("pt-BR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings          UserSettings?
  categories        Category[]
  transactions      Transaction[]
  goals             Goal[]
  assets            Asset[]
  linkedAccounts    LinkedAccount[]
  chatConversations ChatConversation[]
  monthlySnapshots  MonthlySnapshot[]
  bills             Bill[]

  @@map("profiles")
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

model UserSettings {
  id                  String   @id @default(uuid())
  profileId           String   @unique
  profile             Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  theme               Theme    @default(SYSTEM)
  monthStartDay       Int      @default(1)
  notifyUpcomingBills Boolean  @default(true)
  aiAssistantEnabled  Boolean  @default(true)
  onboardingCompleted Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("user_settings")
}

// ─────────────────────────────────────────────────────────
// Financial control
// ─────────────────────────────────────────────────────────

enum CategoryType {
  INCOME
  EXPENSE
}

model Category {
  id         String       @id @default(uuid())
  profileId  String
  profile    Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name       String
  type       CategoryType
  icon       String?
  color      String?
  isDefault  Boolean      @default(false)
  isArchived Boolean      @default(false)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  transactions Transaction[]
  bills        Bill[]

  @@unique([profileId, name, type])
  @@map("categories")
}

enum TransactionType {
  INCOME
  EXPENSE
}

model Transaction {
  id               String            @id @default(uuid())
  profileId        String
  profile          Profile           @relation(fields: [profileId], references: [id], onDelete: Cascade)
  categoryId       String?
  category         Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  type             TransactionType
  amountCents      Int
  currency         String            @default("BRL")
  description      String
  note             String?
  date             DateTime
  dueDate          DateTime?
  isPaid           Boolean           @default(true)
  isRecurring      Boolean           @default(false)
  recurrenceRule   String?
  linkedAccountId  String?
  linkedAccount    LinkedAccount?    @relation(fields: [linkedAccountId], references: [id], onDelete: SetNull)
  goalContribution GoalContribution?
  bill             Bill?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([profileId, date])
  @@index([profileId, categoryId])
  @@index([profileId, isPaid, dueDate])
  @@map("transactions")
}

// ─────────────────────────────────────────────────────────
// Goals
// ─────────────────────────────────────────────────────────

enum GoalStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

model Goal {
  id                 String     @id @default(uuid())
  profileId          String
  profile            Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name               String
  emoji              String?
  targetAmountCents  Int
  currentAmountCents Int        @default(0)
  targetDate         DateTime?
  status             GoalStatus @default(ACTIVE)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  contributions GoalContribution[]

  @@index([profileId, status])
  @@map("goals")
}

model GoalContribution {
  id            String       @id @default(uuid())
  goalId        String
  goal          Goal         @relation(fields: [goalId], references: [id], onDelete: Cascade)
  transactionId String?      @unique
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  amountCents   Int
  date          DateTime     @default(now())
  note          String?
  createdAt     DateTime     @default(now())

  @@index([goalId, date])
  @@map("goal_contributions")
}

// ─────────────────────────────────────────────────────────
// Net worth (prepared, minimal)
// ─────────────────────────────────────────────────────────

enum AssetType {
  CASH
  INVESTMENT
  PROPERTY
  VEHICLE
  DEBT
  OTHER
}

model Asset {
  id              String         @id @default(uuid())
  profileId       String
  profile         Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name            String
  type            AssetType
  valueCents      Int
  currency        String         @default("BRL")
  linkedAccountId String?
  linkedAccount   LinkedAccount? @relation(fields: [linkedAccountId], references: [id], onDelete: SetNull)
  asOfDate        DateTime       @default(now())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@map("assets")
}

// ─────────────────────────────────────────────────────────
// Open Finance (prepared, unused in MVP UI)
// ─────────────────────────────────────────────────────────

model Institution {
  id        String   @id @default(uuid())
  name      String
  logoUrl   String?
  country   String   @default("BR")
  createdAt DateTime @default(now())

  linkedAccounts LinkedAccount[]

  @@map("institutions")
}

enum LinkedAccountStatus {
  PENDING
  ACTIVE
  ERROR
  DISCONNECTED
}

model LinkedAccount {
  id            String              @id @default(uuid())
  profileId     String
  profile       Profile             @relation(fields: [profileId], references: [id], onDelete: Cascade)
  institutionId String
  institution   Institution         @relation(fields: [institutionId], references: [id])
  externalId    String?
  provider      String?
  accountType   String?
  lastSyncedAt  DateTime?
  status        LinkedAccountStatus @default(PENDING)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  transactions Transaction[]
  assets       Asset[]

  @@map("linked_accounts")
}

// ─────────────────────────────────────────────────────────
// AI Assistant
// ─────────────────────────────────────────────────────────

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
}

enum MessageFeedback {
  LIKE
  DISLIKE
}

model ChatConversation {
  id        String   @id @default(uuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title     String?
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]

  @@index([profileId, updatedAt])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(uuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           ChatRole
  content        String           @db.Text
  provider       String?
  feedback       MessageFeedback?
  metadata       Json?
  createdAt      DateTime         @default(now())

  @@index([conversationId, createdAt])
  @@map("chat_messages")
}

// ─────────────────────────────────────────────────────────
// Aggregation
// ─────────────────────────────────────────────────────────

model MonthlySnapshot {
  id                  String   @id @default(uuid())
  profileId           String
  profile             Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  yearMonth           String
  totalIncomeCents    Int
  totalExpenseCents   Int
  totalSavingsCents   Int
  categoryBreakdown   Json
  topGainerCategoryId String?
  topShrinkCategoryId String?
  isFinalized         Boolean  @default(false)
  generatedAt         DateTime @default(now())

  @@unique([profileId, yearMonth])
  @@map("monthly_snapshots")
}

// ─────────────────────────────────────────────────────────
// Bills (Contas a Pagar)
// ─────────────────────────────────────────────────────────

enum BillType {
  ONE_TIME
  INSTALLMENT
  RECURRING
}

/// PENDING/PAID/CANCELLED are the only stored states — a bill has no
/// background job to flip it automatically. "Atrasada" (overdue) and
/// "Agendada" (scheduled) are derived at read time from a PENDING bill's
/// dueDate (see getEffectiveStatus in src/features/bills/service.ts).
enum BillStatus {
  PENDING
  PAID
  CANCELLED
}

enum BillPriority {
  LOW
  MEDIUM
  HIGH
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  DEBIT_CARD
  BOLETO
  CASH
  BANK_TRANSFER
  OTHER
}

enum RecurrenceFrequency {
  WEEKLY
  MONTHLY
  YEARLY
  CUSTOM
}

/// A bill does not affect any financial total while PENDING — it only
/// becomes a real Transaction (cash-basis) once markBillAsPaid() runs,
/// which is the sole integration point with Dashboard/Month-end/
/// Retrospective (they only ever aggregate Transaction, unmodified).
model Bill {
  id                  String               @id @default(uuid())
  profileId           String
  profile             Profile              @relation(fields: [profileId], references: [id], onDelete: Cascade)
  categoryId          String?
  category            Category?            @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  name                String
  description         String?
  note                String?
  amountCents         Int
  currency            String               @default("BRL")
  type                BillType             @default(ONE_TIME)
  status              BillStatus           @default(PENDING)
  priority            BillPriority         @default(MEDIUM)
  tags                String[]             @default([])
  dueDate             DateTime
  paidAt              DateTime?
  paymentMethod       PaymentMethod?
  paymentAccount      String?
  installmentGroupId  String?
  installmentNumber   Int?
  installmentTotal    Int?
  recurrenceGroupId   String?
  recurrenceFrequency RecurrenceFrequency?
  recurrenceRule      String?
  recurrenceIndex     Int?
  /// Type-agnostic series identifier — mirrors installmentGroupId/recurrenceGroupId
  /// so "this/future/all" edit-scope logic doesn't need to branch on BillType.
  /// See resolveSeriesScope in src/features/bills/service.ts.
  seriesId            String?
  transactionId       String?              @unique
  transaction         Transaction?         @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([profileId, dueDate])
  @@index([profileId, status])
  @@index([installmentGroupId])
  @@index([recurrenceGroupId])
  @@index([profileId, seriesId])
  @@map("bills")
}

# ── Database (Supabase Postgres, used by Prisma) ──────────────────────────
# Use the "Connection pooling" string from Supabase (Transaction mode, port 6543)
# for DATABASE_URL. If `prisma migrate` fails through the pooler, temporarily
# swap in the direct connection string (port 5432) to run migrations.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ── Supabase (Auth) ────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SERVICE-ROLE-KEY]"

# ── AI assistant ───────────────────────────────────────────────────────────
# mock = canned responses, no network call, no key required (MVP default)
# anthropic = real Claude calls via @anthropic-ai/sdk (requires ANTHROPIC_API_KEY)
AI_PROVIDER="mock"
ANTHROPIC_API_KEY=""

# ── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

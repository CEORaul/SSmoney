# ── Database (Supabase Postgres, used by Prisma) ──────────────────────────
# Use the "Connection pooling" string from Supabase (Transaction mode, port 6543)
# for DATABASE_URL. If `prisma migrate` fails through the pooler, temporarily
# swap in the direct connection string (port 5432) to run migrations.
#
# On Vercel: the direct db.[ref].supabase.co host is frequently unreachable
# from serverless functions (P1001 "Can't reach database server" — it's
# IPv6-only unless the project has the IPv4 add-on). src/lib/prisma.ts
# already prefers Vercel's auto-provisioned POSTGRES_PRISMA_URL/POSTGRES_URL
# (pooled) over DATABASE_URL when present, but DATABASE_URL itself should
# still point at the pooled string, not the direct one, for local parity.
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"

# ── Supabase (Auth) ────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[YOUR-ANON-KEY]"
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SERVICE-ROLE-KEY]"

# ── AI assistant ───────────────────────────────────────────────────────────
# mock = canned responses, no network call, no key required (dev-only opt-in)
# anthropic = real Claude calls via @anthropic-ai/sdk (production default, requires ANTHROPIC_API_KEY)
# gemini = real Gemini calls via @google/genai (requires GEMINI_API_KEY)
AI_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""
# Latest recommended model; falls back to claude-opus-4-8 if left empty
ANTHROPIC_MODEL=""
# Falls back to 8192 if left empty
ANTHROPIC_MAX_TOKENS=""
# 0.0-1.0; falls back to 0.4 if left empty (lower = more consistent/deterministic)
ANTHROPIC_TEMPERATURE=""
# Falls back to 2 if left empty
ANTHROPIC_MAX_RETRIES=""
# Milliseconds; falls back to 60000 if left empty
ANTHROPIC_TIMEOUT_MS=""

GEMINI_API_KEY=""
# Falls back to gemini-2.5-flash if left empty
GEMINI_MODEL=""
# Falls back to 8192 if left empty
GEMINI_MAX_TOKENS=""
# 0.0-1.0; falls back to 0.4 if left empty
GEMINI_TEMPERATURE=""
# Falls back to 2 if left empty
GEMINI_MAX_RETRIES=""
# Milliseconds; falls back to 60000 if left empty
GEMINI_TIMEOUT_MS=""

# ── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Comma-separated emails allowed into /admin/feedbacks. Fails closed — leave
# empty (or unset) and nobody gets in, including you, until it's set.
ADMIN_EMAILS=""
